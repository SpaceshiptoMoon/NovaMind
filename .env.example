# ========================================
# 智能知识库系统 - 环境变量示例
# ========================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# Docker Compose 会自动读取 .env 文件
# 后端配置已硬编码在 YAML 文件中，这些变量仅用于 docker-compose.yml 覆盖

# MySQL
MYSQL_ROOT_PASSWORD=***REMOVED***
MYSQL_DATABASE=novamind_db

# MinIO
MINIO_ROOT_USER=***REMOVED***
MINIO_ROOT_PASSWORD=***REMOVED***

# Elasticsearch
ES_JAVA_OPTS=-Xms512m -Xmx512m
