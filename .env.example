# ========================================
# NovaMind 环境配置
# ========================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# Docker Compose 和后端 YAML 配置均从此文件读取密码
# 所有 ${VAR_NAME} 在 docker.yaml 中被 YAML loader 自动解析

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=your-mysql-password
MYSQL_DATABASE=novamind_db

# ---- MinIO ----
MINIO_ROOT_USER=your-minio-access-key
MINIO_ROOT_PASSWORD=your-minio-secret-key

# ---- Elasticsearch ----
ES_JAVA_OPTS=-Xms512m -Xmx512m
ES_PASSWORD=your-elasticsearch-password

# ---- 后端安全（Docker 部署用）----
SECRET_KEY=your-jwt-secret-key
ENCRYPTION_KEY=your-aes256-encryption-key

# ---- 管理员账户 ----
ADMIN_PASSWORD=your-admin-password
