# ========================================
# Docker Compose 环境配置（示例）
# ========================================
# 复制此文件为 docker.yaml 并填入真实配置值
# cp docker.example docker.yaml
#
# 服务间通过容器名通信，不使用 localhost
# 此文件会被挂载到后端容器中，通过 --config docker 加载

environment: docker
debug: false

# Redis
redis:
  enabled: true
  host: redis
  port: 6379
  db: 0
  password: null

# MinIO
minio:
  endpoint: minio:9005
  access_key: your-minio-access-key
  secret_key: your-minio-secret-key
  secure: false

# Elasticsearch
elasticsearch:
  hosts:
    - "http://elasticsearch:9200"
  username: elastic
  password: your-es-password

# MySQL
database:
  host: mysql
  port: 3306
  user: root
  password: "your-db-password"
  database: novamind_db

# 日志
logging:
  level: INFO
  format: json
