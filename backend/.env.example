# ========================================
# 智能知识库系统 - 环境配置文件（示例）
# ========================================
# 复制此文件为 .env 并填入真实配置值
# cp .env.example .env
#
# 注意：项目已迁移到 YAML 配置文件（src/setting/yaml_config/yaml/）
# 此 .env 文件仅作为配置参考，实际运行使用 YAML 文件中的配置
# YAML 配置加载顺序: default.yaml → {env}.yaml → local.yaml

# ========== 安全配置 ==========
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== 关系数据库配置 (MySQL/MariaDB) ==========
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=novamind_db

# ========== LLM 配置 ==========
LLM_API_KEY=your-llm-api-key
LLM_MODEL=qwen3.5-27b
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== Embedding 配置 ==========
EMBEDDING_MODEL=embedding-2
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_DIM=1024

# ========== Redis 缓存配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ========== 管理员账户配置 ==========
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
ADMIN_ROLE=admin
CREATE_ADMIN_ON_STARTUP=true
RESET_ADMIN_PASSWORD_IF_EXISTS=false

# ========== CORS 配置 ==========
CORS_ORIGINS=*
