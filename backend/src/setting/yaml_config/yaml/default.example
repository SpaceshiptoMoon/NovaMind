project:
  name: novamind
  version: 0.1.0
  description: novamind backend

security:
  secret_key: "your-secret-key-here"
  algorithm: HS256
  access_token_expire_minutes: 30
  encryption_key: "your-aes256-encryption-key"

database:
  host: localhost
  port: 3306
  user: root
  password: "your-db-password"
  database: novamind_db
  pool_size: 10
  max_overflow: 20
  pool_timeout: 30
  pool_recycle: 3600
  pool_pre_ping: true

redis:
  enabled: false
  host: localhost
  port: 6379
  db: 0
  password: ""

minio:
  endpoint: "127.0.0.1:9005"
  access_key: "your-minio-access-key"
  secret_key: "your-minio-secret-key"
  secure: false
  region: us-east-1
  bucket_name: "novamind-dev"
  # 外部服务（DashScope 等）下载文件时的公网地址，如 https://minio.example.com
  # 本地开发留空即可，部署时必填
  public_endpoint:

elasticsearch:
  hosts:
    - "http://127.0.0.1:9200"
  username: "elastic"
  password: "your-es-password"
  index_prefix: kb
  default_embedding_dim: 1024
  analyzer: standard

vector_db:
  type: elasticsearch

admin:
  username: "admin"
  email: "admin@example.com"
  password: "your-admin-password"
  create_on_startup: true
  reset_password_if_exists: true

cors_origins: "*"

external_search:
  tavily:
    api_key: ""
    max_results: 10
    search_depth: basic
    timeout: 30
  serpapi:
    api_key: ""
    max_results: 10
    timeout: 30
  duckduckgo:
    max_results: 10
    timeout: 15

task_queue:
  max_jobs: 3
  job_timeout: 7200
  max_tries: 3
  retry_base_delay: 60
  queue_name: "arq:queue"

smtp:
  enabled: false
  host: ""
  port: 587
  username: ""
  password: ""
  from_email: ""
  use_tls: true

skill_marketplace:
  llm_review_enabled: false
  llm_review_model: null
