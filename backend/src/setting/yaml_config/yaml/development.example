environment: development

redis:
  enabled: true
  host: localhost
  port: 6379
  db: 0
  password: null

minio:
  endpoint: localhost:9005
  access_key: ${MINIO_ROOT_USER}
  secret_key: ${MINIO_ROOT_PASSWORD}
  secure: false
  # DashScope 等外部云服务下载文件时的公网可达地址，需含协议前缀。
  # 本地开发留空即可（本地 ASR 兜底）；部署时填写如 https://minio.example.com
  public_endpoint:

elasticsearch:
  hosts:
    - "http://localhost:9200"
  username: elastic
  password: your-es-password

database:
  host: localhost
  password: "your-db-password"
