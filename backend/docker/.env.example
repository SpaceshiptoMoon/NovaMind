# NovaMind backend Docker variables
MYSQL_ROOT_PASSWORD=change-me-mysql-password
MYSQL_DATABASE=novamind_db

MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password

ES_JAVA_OPTS=-Xms512m -Xmx512m

SECRET_KEY=change-me-jwt-secret
ENCRYPTION_KEY=change-me-encryption-key
ADMIN_PASSWORD=change-me-admin-password
